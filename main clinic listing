let selected = clinics[0];
let compareList = [];

function renderStars(n) {
  const full = Math.floor(n);
  const half = n % 1 >= 0.5;
  let s = '★'.repeat(full);
  if (half) s += '½';
  return s;
}

function renderClinicList() {
  const container = document.getElementById('clinic-list');
  container.innerHTML = clinics.map(c => `
    <div class="clinic-card ${c.id === selected.id ? 'active' : ''}" onclick="selectClinic(${c.id})">
      <div class="clinic-card-top">
        <div class="clinic-avatar" style="background:${c.bg}">${c.emoji}</div>
        <div style="flex:1">
          <div class="clinic-name">${c.name}</div>
          <div class="clinic-location">📍 ${c.location}</div>
          <div style="margin-top:3px">
            <span class="stars">${renderStars(c.rating)}</span>
            <span class="review-count">${c.rating} (${c.reviews} reviews)</span>
          </div>
        </div>
        ${c.verified ? '<span class="verified-badge">✓ Verified</span>' : ''}
      </div>
      <div class="clinic-tags">
        ${c.tags.map(t => `<span class="tag">${t}</span>`).join('')}
      </div>
      <div class="clinic-price-row">
        <div>
          <div class="price-from">From</div>
          <div class="price-amount">$${c.priceFrom}</div>
        </div>
        <button class="add-compare-btn ${compareList.includes(c.id) ? 'added' : ''}" 
          onclick="event.stopPropagation(); toggleCompare(${c.id})" id="compare-btn-${c.id}">
          ${compareList.includes(c.id) ? '✓ Comparing' : '+ Compare'}
        </button>
      </div>
    </div>
  `).join('');
}

function renderDetail(clinic) {
  const avgRating = clinic.rating;
  const panel = document.getElementById('detail-panel');

  const ratingBars = Object.entries(clinic.ratings).map(([k, v]) => `
    <div class="rating-bar-row">
      <span class="rating-bar-label">${k.charAt(0).toUpperCase() + k.slice(1)}</span>
      <div class="rating-bar-track"><div class="rating-bar-fill" style="width:${v/5*100}%"></div></div>
      <span style="font-size:0.8rem;color:var(--muted);width:28px;text-align:right">${v}</span>
    </div>
  `).join('');

  panel.innerHTML = `
    <div class="detail-hero">
      <div class="detail-hero-bg" style="background:${clinic.bg}">${clinic.emoji}</div>
      <div class="detail-hero-overlay"></div>
      <div class="detail-hero-content">
        <div class="detail-clinic-name">${clinic.name}</div>
        <div class="detail-meta">
          <span>📍 ${clinic.location}</span>
          <span>⭐ ${clinic.rating} · ${clinic.reviews} verified reviews</span>
          ${clinic.verified ? '<span style="background:rgba(46,125,50,0.3);padding:2px 8px;border-radius:100px;font-size:0.75rem">✓ SkinDay Verified</span>' : ''}
        </div>
      </div>
    </div>

    <div class="detail-body">
      <div>
        <p style="color:var(--muted);font-size:0.9rem;line-height:1.75;margin-bottom:2rem">${clinic.about}</p>

        <div class="section-title">Services & Pricing</div>
        <div class="services-grid">
          ${clinic.services.map(s => `
            <div class="service-item">
              <span class="service-name">${s.name}</span>
              <span class="service-price">${s.price}</span>
            </div>
          `).join('')}
        </div>

        <div class="reviews-section">
          <div class="section-title">Client Reviews</div>
          ${clinic.reviewList.map(r => `
            <div class="review-card">
              <div class="review-header">
                <div>
                  <div class="reviewer-name">${r.name}</div>
                  <span class="stars" style="font-size:0.75rem">${'★'.repeat(r.stars)}</span>
                </div>
                <span class="review-verified">✓ Verified client</span>
              </div>
              <div class="review-text">${r.text}</div>
              <div class="review-date">${r.date}</div>
            </div>
          `).join('')}
        </div>
      </div>

      <!-- BOOKING WIDGET -->
      <div>
        <div class="booking-widget">
          <div class="booking-price">From $${clinic.priceFrom} <span>/ session</span></div>
          <div class="booking-stars">
            <span class="stars" style="color:var(--gold)">★★★★★</span>
            ${clinic.rating} · ${clinic.reviews} reviews
          </div>

          <div class="booking-field">
            <label>Treatment</label>
            <select>
              ${clinic.services.map(s => `<option>${s.name} — ${s.price}</option>`).join('')}
            </select>
          </div>
          <div class="booking-field">
            <label>Preferred Date</label>
            <input type="date" min="${new Date().toISOString().split('T')[0]}" />
          </div>
          <div class="booking-field">
            <label>Preferred Time</label>
            <select>
              <option>Morning (9am–12pm)</option>
              <option>Afternoon (12–5pm)</option>
              <option>Evening (5–8pm)</option>
            </select>
          </div>

          <button class="book-btn">Request Booking →</button>
          <div class="booking-note">Free consultation · No commitment</div>
        </div>

        <!-- RATINGS BREAKDOWN -->
        <div style="background:white;border:1px solid var(--border);border-radius:16px;padding:1.5rem;margin-top:1rem">
          <div class="section-title">Rating Breakdown</div>
          <div class="overall-score">
            <div class="score-big">${clinic.rating}</div>
            <div class="stars" style="font-size:1.1rem;color:var(--gold)">${renderStars(clinic.rating)}</div>
            <div class="score-label">${clinic.reviews} verified reviews</div>
          </div>
          ${ratingBars}
        </div>
      </div>
    </div>
  `;
}

function selectClinic(id) {
  selected = clinics.find(c => c.id === id);
  renderClinicList();
  renderDetail(selected);
  document.getElementById('detail-panel').scrollTop = 0;
}

function toggleFilter(el) {
  document.querySelectorAll('.filter-chip').forEach(c => c.classList.remove('active'));
  el.classList.add('active');
}

function toggleCompare(id) {
  const idx = compareList.indexOf(id);
  if (idx > -1) {
    compareList.splice(idx, 1);
  } else {
    if (compareList.length >= 3) {
      alert('You can compare up to 3 clinics at once.');
      return;
    }
    compareList.push(id);
  }
  updateCompareBar();
  renderClinicList();
}

function updateCompareBar() {
  const bar = document.getElementById('compare-bar');
  const pills = document.getElementById('compare-pills');

  if (compareList.length === 0) {
    bar.classList.remove('visible');
    return;
  }

  bar.classList.add('visible');
  pills.innerHTML = compareList.map(id => {
    const c = clinics.find(x => x.id === id);
    return `<div class="compare-pill">${c.emoji} ${c.name.split(' ')[0]} <button onclick="toggleCompare(${id})">×</button></div>`;
  }).join('');
}

function runCompare() {
  if (compareList.length < 2) {
    alert('Add at least 2 clinics to compare!');
    return;
  }
  
  const toCompare = compareList.map(id => clinics.find(c => c.id === id));
  
  // Simple compare modal
  const modal = document.createElement('div');
  modal.style.cssText = `
    position:fixed;inset:0;background:rgba(0,0,0,0.7);z-index:999;
    display:flex;align-items:center;justify-content:center;padding:2rem;
  `;
  
  const categories = ['cleanliness', 'results', 'value', 'communication'];
  
  modal.innerHTML = `
    <div style="background:white;border-radius:20px;padding:2rem;max-width:800px;width:100%;max-height:80vh;overflow-y:auto">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem">
        <h2 style="font-family:'Playfair Display',serif;font-size:1.5rem">Side-by-Side Comparison</h2>
        <button onclick="this.closest('[style*=fixed]').remove()" style="border:none;background:none;font-size:1.5rem;cursor:pointer">×</button>
      </div>
      <div style="display:grid;grid-template-columns:repeat(${toCompare.length},1fr);gap:1rem">
        ${toCompare.map(c => `
          <div style="text-align:center;padding:1rem;background:${c.bg};border-radius:12px">
            <div style="font-size:2rem">${c.emoji}</div>
            <div style="font-family:'Playfair Display',serif;font-weight:700;font-size:0.95rem;margin:0.5rem 0">${c.name}</div>
            <div style="font-size:0.8rem;color:#666">${c.location}</div>
            <div style="font-size:1.4rem;font-family:'Playfair Display',serif;margin:0.5rem 0">${c.rating} ⭐</div>
            <div style="font-size:0.8rem;color:#888">${c.reviews} reviews</div>
            <div style="margin-top:0.5rem;font-weight:700;color:#C8725A">From $${c.priceFrom}</div>
          </div>
        `).join('')}
      </div>
      <table style="width:100%;border-collapse:collapse;margin-top:1.5rem;font-size:0.88rem">
        <tr style="border-bottom:2px solid #EDE8E0">
          <td style="padding:0.7rem;font-weight:600;color:#8A7B72;text-transform:uppercase;font-size:0.75rem;letter-spacing:0.08em">Category</td>
          ${toCompare.map(c => `<td style="padding:0.7rem;text-align:center;font-weight:600">${c.name.split(' ')[0]}</td>`).join('')}
        </tr>
        ${categories.map(cat => `
          <tr style="border-bottom:1px solid #EDE8E0">
            <td style="padding:0.7rem;color:#5A4E48;text-transform:capitalize">${cat}</td>
            ${toCompare.map(c => {
              const val = c.ratings[cat];
              const best = Math.max(...toCompare.map(x => x.ratings[cat]));
              return `<td style="padding:0.7rem;text-align:center;font-weight:${val === best ? '700' : '400'};color:${val === best ? '#C8725A' : '#5A4E48'}">${val} ${val === best ? '🏆' : ''}</td>`;
            }).join('')}
          </tr>
        `).join('')}
        <tr>
          <td style="padding:0.7rem;color:#5A4E48">Starting Price</td>
          ${toCompare.map(c => {
            const cheapest = Math.min(...toCompare.map(x => x.priceFrom));
            return `<td style="padding:0.7rem;text-align:center;font-weight:${c.priceFrom === cheapest ? '700' : '400'};color:${c.priceFrom === cheapest ? '#C8725A' : '#5A4E48'}">$${c.priceFrom} ${c.priceFrom === cheapest ? '💰' : ''}</td>`;
          }).join('')}
        </tr>
      </table>
    </div>
  `;
  
  modal.addEventListener('click', (e) => { if(e.target === modal) modal.remove(); });
  document.body.appendChild(modal);
}

function triggerSearch() {
  // Animate cards briefly
  document.querySelectorAll('.clinic-card').forEach((card, i) => {
    card.style.opacity = '0';
    card.style.transform = 'translateY(10px)';
    setTimeout(() => {
      card.style.transition = 'all 0.3s ease';
      card.style.opacity = '1';
      card.style.transform = 'translateY(0)';
    }, i * 80);
  });
}

// Init
renderClinicList();
renderDetail(selected);
